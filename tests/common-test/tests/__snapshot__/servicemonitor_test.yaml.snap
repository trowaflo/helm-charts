should render ServiceMonitor when enabled:
  1: |
    apiVersion: monitoring.coreos.com/v1
    kind: ServiceMonitor
    metadata:
      labels:
        app.kubernetes.io/component: main
        app.kubernetes.io/instance: common-test
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: service-monitor-name-override
        helm.sh/chart: common-test-0.1.0
        release: prometheus
      name: common-test-service-monitor-name-override-main
      namespace: common-test-namespace-override-test
    spec:
      endpoints:
        - port: main
      selector:
        matchLabels:
          app.kubernetes.io/component: main
          app.kubernetes.io/instance: common-test
          app.kubernetes.io/name: service-monitor-name-override
