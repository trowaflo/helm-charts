should compute fullnameOverride correctly:
  1: |
    apiVersion: networking.k8s.io/v1
    kind: Ingress
    metadata:
      labels:
        app.kubernetes.io/instance: ingress-test
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: common-test
        helm.sh/chart: common-test-0.1.0
      name: my-ingress
      namespace: ingress-test-namespace-override-test
    spec:
      ingressClassName: ""
      rules:
        - host: chart-example.local
          http:
            paths:
              - backend:
                  service:
                    name: my-ingress
                    port:
                      name: main
                path: /
                pathType: Prefix
              - backend:
                  service:
                    name: my-ingress
                    port:
                      name: main
                path: /testpath
                pathType: Prefix
        - host: another-chart-example.local
          http:
            paths:
              - backend:
                  service:
                    name: my-ingress
                    port:
                      name: main
                path: /
                pathType: Prefix
              - backend:
                  service:
                    name: my-ingress
                    port:
                      name: main
                path: /testpath
                pathType: Prefix
