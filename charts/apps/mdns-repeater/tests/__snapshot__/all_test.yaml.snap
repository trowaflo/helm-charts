should match snapshot with default values:
  1: |
    apiVersion: apps/v1
    kind: DaemonSet
    metadata:
      labels:
        app.kubernetes.io/component: main
        app.kubernetes.io/instance: mdns-repeater-testing
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: mdns-repeater-test
        app.kubernetes.io/version: latest
        helm.sh/chart: mdns-repeater-0.1.0
      name: mdns-repeater-testing-main
      namespace: mdns-repeater-test
    spec:
      revisionHistoryLimit: 3
      selector:
        matchLabels:
          app.kubernetes.io/component: main
          app.kubernetes.io/instance: mdns-repeater-testing
          app.kubernetes.io/name: mdns-repeater-test
      template:
        metadata:
          labels:
            app.kubernetes.io/component: main
            app.kubernetes.io/instance: mdns-repeater-testing
            app.kubernetes.io/name: mdns-repeater-test
        spec:
          automountServiceAccountToken: false
          containers:
            - args:
                - eth0
                - eth1
              image: ghcr.io/angelnu/mdns-repeater:latest
              imagePullPolicy: IfNotPresent
              name: main
              resources:
                limits:
                  cpu: 50m
                  memory: 32Mi
                requests:
                  cpu: 1m
                  memory: 16Mi
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  add:
                    - NET_RAW
                  drop:
                    - ALL
                readOnlyRootFilesystem: true
                runAsNonRoot: false
          dnsPolicy: ClusterFirstWithHostNet
          enableServiceLinks: false
          hostNetwork: true
          securityContext:
            fsGroupChangePolicy: OnRootMismatch
            runAsNonRoot: false
            runAsUser: 0
      updateStrategy:
        type: RollingUpdate
