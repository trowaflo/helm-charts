should create a deployment with correct name:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: graphite-exporter
        helm.sh/chart: graphite-exporter-0.0.1
      name: my-graphite-exporter
      namespace: RELEASE-NAME-graphite-exporter
    spec:
      replicas: 1
      revisionHistoryLimit: 3
      selector:
        matchLabels:
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: graphite-exporter
      strategy:
        type: Recreate
      template:
        metadata:
          annotations: null
          labels:
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/name: graphite-exporter
        spec:
          automountServiceAccountToken: false
          containers:
            - env:
                - name: ENVVAR
                  value: TEST
              image: prom/graphite-exporter:v0.16.0@sha256:e54bca6645ea8a9e8c52312a8540de98ad08819d38476c021d77a0eae75bc797
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 3
                httpGet:
                  path: /metrics
                  port: exporter
                  scheme: HTTP
                initialDelaySeconds: 30
                periodSeconds: 10
                successThreshold: 1
                timeoutSeconds: 5
              name: graphite-exporter
              ports:
                - containerPort: 9108
                  name: exporter
                  protocol: TCP
                - containerPort: 9109
                  name: graphite-udp
                  protocol: UDP
                - containerPort: 9109
                  name: graphite-tcp
                  protocol: TCP
              readinessProbe:
                failureThreshold: 3
                httpGet:
                  path: /metrics
                  port: exporter
                  scheme: HTTP
                initialDelaySeconds: 30
                periodSeconds: 10
                successThreshold: 1
                timeoutSeconds: 5
              resources:
                limits:
                  cpu: 100m
                  memory: 64Mi
                requests:
                  cpu: 1m
                  memory: 32Mi
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                runAsUser: 10000
                seccompProfile:
                  type: RuntimeDefault
              startupProbe:
                failureThreshold: 3
                httpGet:
                  path: /metrics
                  port: exporter
                  scheme: HTTP
                initialDelaySeconds: 30
                periodSeconds: 10
                successThreshold: 1
                timeoutSeconds: 5
