should match snapshot with default values:
  1: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/component: main
        app.kubernetes.io/instance: scrypted-testing
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: scrypted-test
        app.kubernetes.io/version: latest
        helm.sh/chart: scrypted-0.1.0
      name: scrypted-testing-main
      namespace: scrypted-test
    spec:
      ports:
        - name: http
          port: 11080
          protocol: TCP
          targetPort: http
        - name: https
          port: 10443
          protocol: TCP
          targetPort: https
      selector:
        app.kubernetes.io/component: main
        app.kubernetes.io/instance: scrypted-testing
        app.kubernetes.io/name: scrypted-test
      type: ClusterIP
  2: |
    apiVersion: apps/v1
    kind: StatefulSet
    metadata:
      labels:
        app.kubernetes.io/component: main
        app.kubernetes.io/instance: scrypted-testing
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: scrypted-test
        app.kubernetes.io/version: latest
        helm.sh/chart: scrypted-0.1.0
      name: scrypted-testing-main
      namespace: scrypted-test
    spec:
      replicas: 1
      revisionHistoryLimit: 3
      selector:
        matchLabels:
          app.kubernetes.io/component: main
          app.kubernetes.io/instance: scrypted-testing
          app.kubernetes.io/name: scrypted-test
      serviceName: scrypted-testing-main
      template:
        metadata:
          labels:
            app.kubernetes.io/component: main
            app.kubernetes.io/instance: scrypted-testing
            app.kubernetes.io/name: scrypted-test
        spec:
          automountServiceAccountToken: false
          containers:
            - image: ghcr.io/koush/scrypted:latest
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 5
                httpGet:
                  path: /
                  port: 11080
                initialDelaySeconds: 30
                periodSeconds: 30
                successThreshold: 1
                timeoutSeconds: 5
              name: main
              ports:
                - containerPort: 11080
                  name: http
                  protocol: TCP
                - containerPort: 10443
                  name: https
                  protocol: TCP
              readinessProbe:
                failureThreshold: 3
                httpGet:
                  path: /
                  port: 11080
                initialDelaySeconds: 15
                periodSeconds: 10
                successThreshold: 1
                timeoutSeconds: 5
              resources:
                limits:
                  cpu: 2000m
                  memory: 1Gi
                requests:
                  cpu: 100m
                  memory: 256Mi
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
                readOnlyRootFilesystem: false
                runAsNonRoot: false
              volumeMounts:
                - mountPath: /server/volume
                  name: config
          enableServiceLinks: false
          securityContext:
            fsGroup: 0
            fsGroupChangePolicy: OnRootMismatch
            runAsNonRoot: false
            runAsUser: 0
      updateStrategy:
        type: RollingUpdate
      volumeClaimTemplates:
        - metadata:
            name: config
          spec:
            accessModes:
              - ReadWriteOnce
            resources:
              requests:
                storage: 10Gi
