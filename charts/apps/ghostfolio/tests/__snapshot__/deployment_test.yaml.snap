        app.kubernetes.io/instance: ghostfolio-test
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: ghostfolio
        helm.sh/chart: ghostfolio-7.0.0
      name: ghostfolio-test-main
      namespace: ghostfolio-test
    spec:
      replicas: 1
      revisionHistoryLimit: 3
      selector:
        matchLabels:
          app.kubernetes.io/component: main
          app.kubernetes.io/instance: ghostfolio-test
          app.kubernetes.io/name: ghostfolio
      strategy:
        type: Recreate
      template:
        metadata:
          labels:
            app.kubernetes.io/component: main
            app.kubernetes.io/instance: ghostfolio-test
            app.kubernetes.io/name: ghostfolio
        spec:
          automountServiceAccountToken: false
          containers:
            - env:
                - name: ACCESS_TOKEN_SALT
                  valueFrom:
                    secretKeyRef:
                      key: ACCESS_TOKEN_SALT
                      name: ghostfolio-test-auth
                - name: DATABASE_URL
                  valueFrom:
                    secretKeyRef:
                      key: uri
                      name: ghostfolio-test-postgresql-app
                - name: JWT_SECRET_KEY
                  valueFrom:
                    secretKeyRef:
                      key: JWT_SECRET_KEY
                      name: ghostfolio-test-auth
                - name: NODE_ENV
                  value: production
                - name: REDIS_HOST
                  value: ghostfolio-test-redis
                - name: REDIS_PASSWORD
                  valueFrom:
                    secretKeyRef:
                      key: REDIS_PASSWORD
                      name: ghostfolio-test-redis
                - name: REDIS_PORT
                  value: "6379"
              image: ghostfolio/ghostfolio:2.255.0@sha256:d3ed46a9a5c82db4457ff919be07f02add26e9f5f116be86793ced9aa422e6d3
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 3
                httpGet:
                  path: /api/v1/health
                  port: http
                  scheme: HTTP
                initialDelaySeconds: 30
                periodSeconds: 10
                successThreshold: 1
                timeoutSeconds: 5
              name: main
              ports:
                - containerPort: 3333
                  name: http
                  protocol: TCP
              readinessProbe:
                failureThreshold: 3
                httpGet:
                  path: /api/v1/health
                  port: http
                  scheme: HTTP
                initialDelaySeconds: 10
                periodSeconds: 5
                successThreshold: 1
                timeoutSeconds: 3
              resources:
                limits:
