should match snapshot:
  1: |
    apiVersion: batch/v1
    kind: CronJob
    metadata:
      labels:
        app.kubernetes.io/component: backup
        app.kubernetes.io/instance: ghostfolio-test
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: ghostfolio-backup
        helm.sh/chart: ghostfolio-0.1.0
      name: ghostfolio-test-backup
      namespace: ghostfolio-test
    spec:
      concurrencyPolicy: Forbid
      failedJobsHistoryLimit: 3
      jobTemplate:
        spec:
          template:
            metadata:
              labels:
                app.kubernetes.io/instance: ghostfolio-test
                app.kubernetes.io/name: ghostfolio-backup
            spec:
              containers:
                - command:
                    - /bin/bash
                    - -c
                    - |
                      set -e

                      # Generate backup filename with timestamp
                      BACKUP_FILE="/backup/ghostfolio-$(date +%Y-%m-%d-%H%M%S).dump"

                      echo "Starting backup to $BACKUP_FILE"

                      # Perform pg_dump with custom format
                      pg_dump -Fc -v -f "$BACKUP_FILE" "$DATABASE_URL"

                      echo "Backup completed: $BACKUP_FILE"

                      # Verify backup integrity
                      echo "Verifying backup integrity..."
                      pg_restore --list "$BACKUP_FILE" > /dev/null
                      echo "Backup verification successful"

                      # Cleanup old backups (keep last N)
                      echo "Cleaning up old backups (keeping last 7)"
                      cd /backup
                      ls -t ghostfolio-*.dump | tail -n +8 | xargs -r rm -f

                      echo "Backup process completed successfully"
                  env:
                    - name: DATABASE_URL
                      valueFrom:
                        secretKeyRef:
                          key: DATABASE_URL
                          name: test-db-secret
                  image: postgres:16
                  imagePullPolicy: IfNotPresent
                  name: backup
                  resources:
                    limits:
                      cpu: 500m
                      memory: 512Mi
                    requests:
                      cpu: 100m
                      memory: 128Mi
                  securityContext:
                    allowPrivilegeEscalation: false
                    capabilities:
                      drop:
                        - ALL
                    readOnlyRootFilesystem: false
                  volumeMounts:
                    - mountPath: /backup
                      name: backup
              restartPolicy: OnFailure
              securityContext:
                fsGroup: 999
                runAsGroup: 999
                runAsNonRoot: true
                runAsUser: 999
              volumes:
                - name: backup
                  nfs:
                    path: /mnt/backups
                    server: 192.168.1.100
      schedule: 0 2 * * *
      successfulJobsHistoryLimit: 3
