should match snapshot:
  1: |
    apiVersion: batch/v1
    kind: CronJob
    metadata:
      labels:
        app.kubernetes.io/component: backup
        app.kubernetes.io/instance: ghostfolio-test
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: ghostfolio
        helm.sh/chart: ghostfolio-14.0.0
      name: ghostfolio-test-backup
      namespace: ghostfolio-test
    spec:
      concurrencyPolicy: Forbid
      failedJobsHistoryLimit: 3
      jobTemplate:
        spec:
          template:
            metadata:
              labels:
                app.kubernetes.io/component: backup
                app.kubernetes.io/instance: ghostfolio-test
                app.kubernetes.io/name: ghostfolio
            spec:
              automountServiceAccountToken: false
              containers:
                - command:
                    - /bin/bash
                    - -c
                    - |
                      set -e
                      BACKUP_FILE="/backup/ghostfolio-$(date +%Y-%m-%d-%H%M%S).dump"
                      echo "Starting backup to $BACKUP_FILE"
                      pg_dump -Fc -v -f "$BACKUP_FILE" "$DATABASE_URL"
                      echo "Backup completed: $BACKUP_FILE"
                      echo "Verifying backup integrity..."
                      pg_restore --list "$BACKUP_FILE" > /dev/null
                      echo "Backup verification successful"
                      echo "Cleaning up old backups (keeping last {{ .Values.backup.retention | default 7 }})"
                      cd /backup
                      ls -t ghostfolio-*.dump | tail -n +{{ add1 (.Values.backup.retention | default 7) }} | xargs -r rm -f
                      echo "Backup process completed successfully"
                  env:
                    - name: DATABASE_URL
                      valueFrom:
                        secretKeyRef:
                          key: uri
                          name: ghostfolio-test-postgresql-app
                  image: postgres:16@sha256:71e27bf60b70bded003791b5573f8b808365613f341df20ffcf0c1ed7bc13ddf
                  imagePullPolicy: IfNotPresent
                  name: backup
                  resources:
                    limits:
                      cpu: 500m
                      memory: 512Mi
                    requests:
                      cpu: 100m
                      memory: 128Mi
                  securityContext:
                    allowPrivilegeEscalation: false
                    capabilities:
                      drop:
                        - ALL
                    readOnlyRootFilesystem: false
                    runAsNonRoot: true
                  volumeMounts:
                    - mountPath: /backup
                      name: backup
              enableServiceLinks: false
              restartPolicy: OnFailure
              securityContext:
                fsGroup: 999
                fsGroupChangePolicy: OnRootMismatch
                runAsGroup: 999
                runAsNonRoot: true
                runAsUser: 999
              volumes:
                - name: backup
                  nfs:
                    path: /mnt/backups
                    server: 192.168.1.100
      schedule: 0 2 * * *
      successfulJobsHistoryLimit: 3
